// --- Configuration des Pins ---
 
#define X_STEP_PIN A0
#define X_DIR_PIN A1
#define X_ENABLE_PIN 38
 
#define Y_STEP_PIN A6
#define Y_DIR_PIN A7
#define Y_ENABLE_PIN A2


 
//pin des LED, on peut en ajouter si on en a plusieurs
int ledPin = 50; // Pin connectée à la LED

//pin queue
int queuePin=53;
//pin gueule
int gueulePin=41;
 
// --- Paramètres Physiques ---
const float diametre = 0.075;  
const float pi = 3.14159;
const float entraxe = 0.125;    
const int pasParTour = 3200;    
 
// --- Paramètres de Vitesse ---
const int delaiCible = 250;        // BOOST : Plus rapide en ligne droite (était à 200)
const int delaiTournerCible = 600; // ON GARDE : Rotation parfaite
const int delaiDepart = 1200;      // ON GARDE : Démarrage ultra-doux pour l'adhérence
 
// --- RÉGLAGES NUMÉRIQUES FIXES (Adaptés à la nouvelle vitesse) ---
const long ACCEL_FIXE = 2000;  // AUGMENTÉ : Plus de pas pour atteindre 150 sans patiner
const long DECEL_FIXE = 1000;  // AUGMENTÉ : Plus de pas pour freiner sans glisser vers l'avant
 
// --- Directions ---
const bool X_avant = HIGH;
const bool Y_avant = LOW;
//configuration queue
#include <Servo.h>

Servo queue;
Servo gueule;
 
void setupQueue(); 
void setupGeule();
void bougerGueule();
 
void setup() {
  pinMode(ledPin, OUTPUT); // Déclare la LED comme sortie

  pinMode(X_STEP_PIN, OUTPUT);
  pinMode(X_DIR_PIN, OUTPUT);
  pinMode(X_ENABLE_PIN, OUTPUT);
  pinMode(Y_STEP_PIN, OUTPUT);
  pinMode(Y_DIR_PIN, OUTPUT);
  pinMode(Y_ENABLE_PIN, OUTPUT);
 
 // a allumer si les moteurs ne démarrent pas immédiatement
  //digitalWrite(X_ENABLE_PIN, LOW);
  //digitalWrite(Y_ENABLE_PIN, LOW);
  
    //Debug
  Serial.begin(115200);

  // Servo Queue
  queue.attach(queuePin);
  //setupQueue();

  // Servo Geuel 
  gueule.attach(gueulePin);
  //setupGeule();

  delay(1000);

  //bougerGueule();

}
 
void moteurMove(long pas, int d_initial, int d_cible, bool dirX, bool dirY) {
  if (pas <= 0) return;
 
  digitalWrite(X_DIR_PIN, dirX);
  digitalWrite(Y_DIR_PIN, dirY);
  delay(100);
 
  // Ajustement automatique si le trajet est plus court que les rampes
float ratio_accel = 0.3;
float ratio_decel = 0.1;
 
long v_accel = ACCEL_FIXE*ratio_accel;
long v_decel = DECEL_FIXE*ratio_decel;
 
  if (v_accel + v_decel > pas) {
    v_accel = pas / 2;
    v_decel = pas / 2;
  }
 
  for (long i = 0; i < pas; i++) {
    digitalWrite(X_STEP_PIN, HIGH);
    digitalWrite(Y_STEP_PIN, HIGH);
    delayMicroseconds(20);
    digitalWrite(X_STEP_PIN, LOW);
    digitalWrite(Y_STEP_PIN, LOW);
 
    long d_actuel;
   
    if (i < v_accel) {
      d_actuel = d_initial - ((long)(d_initial - d_cible) * i / v_accel);
    }
    else if (i > (pas - v_decel)) {
      long j = i - (pas - v_decel);
      d_actuel = d_cible + ((long)(d_initial - d_cible) * j / v_decel);
    }
    else {
      d_actuel = d_cible;
    }
 
    if (d_actuel < d_cible) d_actuel = d_cible;
    delayMicroseconds(d_actuel);
  }
  delay(300);
}
 
void avancer(float distanceMetre, bool versAvant) {
  float circonference = pi * diametre;
  long pas = (distanceMetre / circonference) * pasParTour;
  bool dirX = versAvant ? X_avant : !X_avant;
  bool dirY = versAvant ? Y_avant : !Y_avant;
 
  moteurMove(pas, delaiDepart, delaiCible, dirX, dirY);
}
 
void tourner(float angleDegre, bool sensHoraire) {
  float d_roue = (angleDegre / 360.0) * pi * entraxe;
  float circonferenceRoue = pi * diametre;
  long pas = (d_roue / circonferenceRoue) * pasParTour;
  bool dirX = sensHoraire ? X_avant : !X_avant;
  bool dirY = sensHoraire ? !Y_avant : Y_avant;
 
  // Utilise toujours la vitesse lente de rotation pour la précision
  moteurMove(pas, delaiDepart, delaiTournerCible, dirX, dirY);
}

void setupQueue(){
  // go 180 hne back to 90
  Serial.print("Queue : Setup 180");
  queue.write(0); // à gauche
  delay(500);
   Serial.print("   Setup 90");
  queue.write(90); // à droite
  delay(500);

   Serial.println("Setup end");
}

void remuerQueue()
{
  //à changer si le servo est installé différement
  int centre = 90;     // verticale
  int amplitude = 55;  // 45° de chaque côté //65
 
  for(int i = 0; i < 3; i++) //3 aller-retour de la queue
  {
    int gauche = centre - amplitude;
    int droite = centre + amplitude;
    Serial.print("Gauche is :");
    Serial.println(gauche);
    Serial.print("Droite is :");
    Serial.println(droite);
    queue.write(gauche); // à gauche
    delay(500);
    queue.write(droite); // à droite
    delay(500);
  }
 
  queue.write(centre); // revenir au centre
}
void setupGeule(){
  // go 180 hne back to 90
  Serial.print("Geule : Setup 0");
  gueule.write(90); // à gauche
  delay(500);
  Serial.println("Setup end");

}
void bougerGueule()
{
  int ferme = 83;   // position fermée
  int ouvert = 41; // position ouverte
  int pause = 500;  // temps en ms que la gueule reste ouverte
  Serial.println("Ouvire la geule");
  gueule.write(ouvert);  // ouvrir
  delay(pause);           // attendre
  Serial.println("Fermer la geule");
  gueule.write(ferme);    // refermer
}
 
void clignoterLED() {
  for(int i = 0; i < 3; i++) {
    digitalWrite(ledPin, HIGH); // LED allumée
    delay(500);                 // attendre 300 ms (changer le délai selon notre besoin)
    digitalWrite(ledPin, LOW);  // LED éteinte
    delay(1000);                 // attendre 300 ms
  }
 
}

void moteursOFF() {
  digitalWrite(X_ENABLE_PIN, HIGH); //OFF
  digitalWrite(Y_ENABLE_PIN, HIGH); // OFF 
}

void moteursON() {
  digitalWrite(X_ENABLE_PIN, LOW);  // ON
  digitalWrite(Y_ENABLE_PIN, LOW);  // ON
  delay(100);
}

void loop() {

  avancer(0.6, true);
  delay(100); //essayer de changer a moins de 500
  tourner(44, false);  //baissé de 2
  delay(100);
  avancer(0.205, true);
  delay(100);
  bougerGueule();
  delay(500);
  avancer(0.225, false);
  delay(100); //a partir dici
  tourner(90, false);  
  delay(100);
  moteursOFF();
  delay(100);
  clignoterLED();
  delay(100);
  moteursON();
  tourner(42, true);  //ajouté 2 degré
  delay(100);
  avancer(1.28, true);
  delay(100);
  tourner(135, false);
  delay(100);
  remuerQueue();
  moteursOFF();
  delay(25000); //mettre a 25000
  moteursON();
  tourner(44, true);  
  delay(100);
  avancer(0.6, true);
  delay(100);
  tourner(285, true);  
  delay(500);
  moteursOFF();
  while(1){}
}
